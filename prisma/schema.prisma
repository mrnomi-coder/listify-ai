generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductStatus { DRAFT PROCESSING READY PUBLISHED FAILED }
enum BrandVoice { LUXURY MINIMAL TRENDY PREMIUM FASHION TECH }
enum BillingPlan { STARTER GROWTH SCALE }

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  passwordHash       String
  role               String              @default("seller")
  image              String?
  products           Product[]
  brandVoicePrompts  BrandVoicePrompt[]
  shopifyConnections ShopifyConnection[]
  subscription       BillingSubscription?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model BrandVoicePrompt {
  id        String     @id @default(cuid())
  userId    String?
  voice     BrandVoice
  label     String
  prompt    String
  isDefault Boolean    @default(false)
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  @@unique([userId, voice])
}

model Product {
  id                String        @id @default(cuid())
  userId            String
  imageUrl          String?
  sourceUrl         String?
  price             Decimal       @db.Decimal(10, 2)
  currency          String        @default("USD")
  rawNotes          String?
  name              String?
  category          String?
  commonMarketName  String?
  seoTitle          String?
  shortDescription  String?
  longDescription   String?
  bulletFeatures    String[]      @default([])
  specifications    Json?
  tags              String[]      @default([])
  seoKeywords       String[]      @default([])
  competitorNotes   Json?
  metaDescription   String?
  suggestedCategory String?
  brandVoice        BrandVoice    @default(MINIMAL)
  confidence        Int           @default(0)
  status            ProductStatus @default(DRAFT)
  aiInputs          Json?
  aiOutput          Json?
  shopifyProductId  String?
  publishedAt       DateTime?
  generatedAt       DateTime?
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets            ProductAsset[]
  jobs              AiJob[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  @@index([userId, status])
  @@index([createdAt])
}

model ProductAsset {
  id        String   @id @default(cuid())
  productId String
  url       String
  publicId  String?
  position  Int      @default(0)
  alt       String?
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model AiJob {
  id        String        @id @default(cuid())
  productId String?
  userId    String
  type      String
  status    ProductStatus @default(PROCESSING)
  progress  Int           @default(0)
  error     String?
  payload   Json
  result    Json?
  product   Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  @@index([userId, status])
}

model ShopifyConnection {
  id                String   @id @default(cuid())
  userId            String
  shop              String
  accessTokenCipher String
  scopes            String[]
  isActive          Boolean  @default(true)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@unique([userId, shop])
}

model BillingSubscription {
  id               String      @id @default(cuid())
  userId           String      @unique
  plan             BillingPlan @default(STARTER)
  stripeCustomerId String?
  stripeSubId      String?
  status           String      @default("trialing")
  renewsAt         DateTime?
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}
